# Variáveis principais
set $mod Mod4
set $term foot
set $naveg firefox
set $menu wofi --show drun

# Aplicações principais
bindsym $mod+Return exec $term
bindsym $mod+w exec $naveg
bindsym $mod+d exec $menu
bindsym $mod+Shift+q kill

# Recarregar / sair
bindsym $mod+Shift+c reload
bindsym $mod+Shift+e exec swaynag -t warning -m 'Sair do Sway?' -b 'Sim' 'swaymsg exit'

# Foco com hjkl
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

# Foco com setas
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

# Mover janelas
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

# Aparência das janelas
gaps inner 10
gaps outer 5
smart_gaps off
default_border pixel 2
default_floating_border pixel 2
# Garantir gaps no workspace atual após reload
exec_always swaymsg gaps inner current set 10
exec_always swaymsg gaps outer current set 5

# Bordas das janelas
default_border pixel 2
default_floating_border pixel 2

# Layouts
bindsym $mod+b splith
bindsym $mod+v splitv
bindsym $mod+s layout stacking
bindsym $mod+q layout tabbed
bindsym $mod+e layout toggle split
bindsym $mod+f fullscreen toggle
bindsym $mod+Shift+space floating toggle
bindsym $mod+space focus mode_toggle

# Workspaces
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10

# Teclado ABNT2 - Português Brasil
input type:keyboard {
    xkb_layout br
    xkb_variant abnt2
    xkb_model abnt2
}

# Screenshots
bindsym Print exec mkdir -p ~/Imagens/Screenshots && grim ~/Imagens/Screenshots/screenshot-$(date +'%Y-%m-%d-%H%M%S').png
bindsym Shift+Print exec mkdir -p ~/Imagens/Screenshots && grim -g "$(slurp)" ~/Imagens/Screenshots/screenshot-$(date +'%Y-%m-%d-%H%M%S').png
bindsym Ctrl+Print exec grim -g "$(slurp)" - | wl-copy

# Áudio
bindsym XF86AudioRaiseVolume exec pactl set-sink-volume @DEFAULT_SINK@ +5%
bindsym XF86AudioLowerVolume exec pactl set-sink-volume @DEFAULT_SINK@ -5%
bindsym XF86AudioMute exec pactl set-sink-mute @DEFAULT_SINK@ toggle
bindsym XF86AudioMicMute exec pactl set-source-mute @DEFAULT_SOURCE@ toggle

# Brilho
bindsym XF86MonBrightnessUp exec brightnessctl set +5%
bindsym XF86MonBrightnessDown exec brightnessctl set 5%-

# Programas úteis
bindsym $mod+t exec thunar
bindsym $mod+n exec foot -e nmtui
bindsym $mod+Shift+n exec nwg-look

# Papel de parede
output * bg $HOME/.local/share/backgrounds/void.png fill

# Audio start pipewire
exec --no-startup-id pipewire
exec --no-startup-id wireplumber
exec --no-startup-id pipewire-pulse

# Audio start pulseaudio
#exec --no-startup-id pulseaudio

# Applet gráfico do NetworkManager na bandeja
exec_always sh -c 'pkill nm-applet; nm-applet --indicator'

# Agente Polkit
exec /usr/libexec/polkit-mate-authentication-agent-1

# Múltiplos monitores
exec_always sh -c 'pkill kanshi; kanshi'

# Histórico de clipboard
exec wl-paste --type text --watch cliphist store
exec wl-paste --type image --watch cliphist store
bindsym $mod+Shift+v exec cliphist list | wofi --dmenu | cliphist decode | wl-copy

# Notificações
exec_always sh -c 'pkill mako; mako'

# Inibir idle quando houver áudio
exec sway-audio-idle-inhibit

# Idle e lock - modo seguro para VM
exec_always sh -c 'pkill swayidle; swayidle -w timeout 600 "swaylock -f -c 000000" before-sleep "swaylock -f -c 000000"'

# Força religar saídas de vídeo
bindsym $mod+Shift+o output * power on

# Portais Wayland
exec dbus-update-activation-environment WAYLAND_DISPLAY XDG_CURRENT_DESKTOP=sway

# Waybar
bar {
    mode invisible
}

exec_always sh -c 'pkill waybar; waybar'

